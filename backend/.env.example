# ============================================================================
# StockTrader — Backend Environment Variables
# Copy this file to `.env` and fill in the real values.
# ============================================================================

# --- Database ---------------------------------------------------------------
# PostgreSQL connection string. Local example or hosted (Neon / Supabase / Render).
# Must include `sslmode=require` for hosted Postgres.
# The AI feature requires the pgvector extension (enabled automatically by the
# migration in prisma/migrations/).
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# --- Auth -------------------------------------------------------------------
# Long random string used to sign JWTs. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="generate_a_strong_random_string"

# --- Server -----------------------------------------------------------------
PORT=3000

# --- AI / RAG (Gemini) ------------------------------------------------------
# Get a free API key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your_gemini_api_key"

# Where uploaded PDFs are stored on disk (relative to backend/).
UPLOAD_DIR=./uploads

# Maximum PDF file size accepted by the /api/ai/upload endpoint.
MAX_PDF_SIZE_MB=10

# --- ML Prediction Service --------------------------------------------------
# URL of the Python FastAPI service that serves stock price-direction
# predictions (see ml-service/). Run it with:
#   cd ml-service && uvicorn app:app --port 8000
ML_SERVICE_URL=http://localhost:8000
